##############################################################
# .env.example — Placement Compass
#
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file to source control.
# In production, inject all variables via Jenkins Credentials
# or your server's environment — not via this file.
##############################################################

# ── Docker Hub ────────────────────────────────────────────
# Your Docker Hub username (used to tag and push images)
DOCKER_HUB_USERNAME=your_dockerhub_username

# Docker image tag applied during deployment (set by Jenkins)
IMAGE_TAG=latest

# ── Deployment ────────────────────────────────────────────
# IP address or hostname of your Ubuntu deployment server
DEPLOY_SERVER=your.server.ip.address

# SSH user on the deployment server (must have Docker access)
DEPLOY_USER=ubuntu

# Public domain name of the app (used in CORS_ORIGINS)
DOMAIN=yourdomain.com

# ── Frontend (Vite build-time variables) ─────────────────
# These are BAKED IN at docker build time via ARG / ENV.
# They identify your Supabase project — NOT server secrets.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── Backend: LLM Provider Keys ────────────────────────────
# Injected at container runtime — never baked into the image.
GOOGLE_API_KEY=
GITHUB_TOKEN=
GROQ_API_KEY=
SAMBANOVA_API_KEY=
DEEPSEEK_API_KEY=

# ── Backend: LangSmith Tracing (optional) ────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=langgraph-pipeline
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Backend: Pipeline Behaviour ───────────────────────────
OUTPUT_DIR=/app/output   # Written inside the container; mounted as a volume
MAX_RETRIES=3
BATCH_SIZE=20
CONCURRENCY_LIMIT=3

# ── Backend: API Server ───────────────────────────────────
API_VERSION=1.0.0

# ── Email Notifications (Jenkins SMTP) ───────────────────
# Configure in Jenkins → Manage Jenkins → Configure System → E-mail Notification
# The values below are consumed by the Jenkinsfile post{} block.
NOTIFICATION_EMAIL=your_email@example.com
