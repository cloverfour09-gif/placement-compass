# ── Node / Build Artefacts ────────────────────────────────
node_modules
dist
dist-ssr
.vite

# ── Dependency Lock (keep package-lock.json for npm ci) ──
# bun.lock and bun.lockb are Bun-specific; we use npm ci in Docker
bun.lock
bun.lockb

# ── Cache ─────────────────────────────────────────────────
.cache
*.tsbuildinfo

# ── Logs ─────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Test Artefacts ────────────────────────────────────────
coverage
.nyc_output
vitest-results

# ── IDE / Editor ──────────────────────────────────────────
.vscode
.idea
*.suo
*.sw?
*.ntvs*
*.njsproj
*.sln

# ── Git ───────────────────────────────────────────────────
.git
.gitignore

# ── OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Environment ───────────────────────────────────────────
.env
.env.local
.env.production
.env.*.local

# ── Backend & other sub-projects (not part of frontend image) ─
Lang graph
mobile-app

# ── Docker files themselves (not needed in build context) ─
docker-compose.yml
Dockerfile
nginx.conf

# ── CI/CD ────────────────────────────────────────────────
Jenkinsfile
scripts
